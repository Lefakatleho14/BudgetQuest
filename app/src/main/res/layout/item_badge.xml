<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/card_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Badge icon circle -->
        <TextView
            android:id="@+id/tvBadgeIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_icon_circle_purple"
            android:gravity="center"
            android:text="🏆"
            android:textSize="22sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

        <!-- Badge title -->
        <TextView
            android:id="@+id/tvBadgeTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:text="Badge Title"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/tvBadgeIcon"
            app:layout_constraintEnd_toStartOf="@id/tvXpReward"
            app:layout_constraintTop_toTopOf="@id/tvBadgeIcon" />

        <!-- Badge description -->
        <TextView
            android:id="@+id/tvBadgeDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            android:text="Description of badge"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/tvBadgeIcon"
            app:layout_constraintEnd_toStartOf="@id/tvXpReward"
            app:layout_constraintTop_toBottomOf="@id/tvBadgeTitle" />

        <!-- Status: unlocked date or "Locked" -->
        <TextView
            android:id="@+id/tvBadgeStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="4dp"
            android:text="Locked"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:textStyle="italic"
            app:layout_constraintStart_toEndOf="@id/tvBadgeIcon"
            app:layout_constraintEnd_toStartOf="@id/tvXpReward"
            app:layout_constraintTop_toBottomOf="@id/tvBadgeDescription" />

        <!-- XP Reward -->
        <TextView
            android:id="@+id/tvXpReward"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="+10 XP"
            android:textColor="@color/teal_700"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvBadgeIcon"
            app:layout_constraintBottom_toBottomOf="@id/tvBadgeIcon" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>