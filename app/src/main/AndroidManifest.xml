<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BudgetQuest"
        tools:targetApi="31">

        <!-- Splash / Entry Point -->
        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Auth -->
        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize" />

        <!-- Main Screens -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

        <activity
            android:name=".ui.category.CategoryActivity"
            android:exported="false"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

        <activity
            android:name=".ui.expense.AddExpenseActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

        <activity
            android:name=".ui.expense.ExpenseListActivity"
            android:exported="false"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

        <activity
            android:name=".ui.budget.BudgetActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

        <activity
            android:name=".ui.reports.CategoryTotalsActivity"
            android:exported="false"
            android:theme="@style/Theme.BudgetQuest.NoActionBar" />

    </application>

</manifest>